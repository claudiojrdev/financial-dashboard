{
  "name": "dashboard-financeiro",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Dashboard de contas a pagar com calendário interativo, multi-usuário e sincronia com servidor.",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch server/index.js",
